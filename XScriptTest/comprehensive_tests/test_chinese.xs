// ============================================
// 中文支持测试脚本
// 测试中文变量名、函数名、字符串和注释
// ============================================

// ------ 测试1: 中文变量名 ------
var 姓名 = "张三";
var 年龄 = 25;
var 城市 = "北京";

printf("--- 测试1: 中文变量名 ---");
printf("姓名: " $ 姓名);
printf("年龄: " $ 年龄);
printf("城市: " $ 城市);

// ------ 测试2: 中文函数名 ------
function 加法(甲, 乙)
{
    return 甲 + 乙;
}

function 求最大值(数值甲, 数值乙, 数值丙)
{
    if ((数值甲 > 数值乙) && (数值甲 > 数值丙))
    {
        return 数值甲;
    }
    else if (数值乙 > 数值丙)
    {
        return 数值乙;
    }
    else
    {
        return 数值丙;
    }
}

printf("--- 测试2: 中文函数名 ---");
printf("加法(10, 20) = " $ 加法(10, 20));
printf("求最大值(3, 7, 5) = " $ 求最大值(3, 7, 5));

// ------ 测试3: 中文字符串操作 ------
printf("--- 测试3: 中文字符串 ---");
var 问候语 = "你好，世界！";
printf(问候语);

var 拼接结果 = "欢迎来到" $ 城市 $ "，" $ 姓名 $ "！";
printf(拼接结果);

// ------ 测试4: 中文循环和条件 ------
printf("--- 测试4: 循环与条件 ---");
var 总和 = 0;
var 计数 = 0;
for (计数 = 1; 计数 <= 10; 计数++)
{
    总和 = 总和 + 计数;
}
printf("1到10的总和 = " $ 总和);

// ------ 测试5: 中文表/数组 ------
printf("--- 测试5: 中文表 ---");
var 学生 = {};
学生.姓名 = "李四";
学生.年龄 = 18;
学生.成绩 = 95;
printf("学生姓名: " $ 学生.姓名);
printf("学生年龄: " $ 学生.年龄);
printf("学生成绩: " $ 学生.成绩);

// ------ 测试6: 中英文混合 ------
printf("--- 测试6: 中英文混合 ---");
var myName = "王五";
var 得分score = 100;
function 计算total(基础分, 加分)
{
    return 基础分 + 加分;
}
printf("name: " $ myName);
printf("总分: " $ 计算total(得分score, 50));

/* 
   这是一个块注释
   用来测试块注释中的中文支持
   没有问题就说明一切正常！
*/

printf("--- 所有中文测试通过！ ---");
system_pause();
