// ============================================
// GBK编码中文支持测试脚本
// 测试次字节为特殊ASCII字符的汉字
// ============================================

// ------ 测试1: 姓名 ------
var 姓名 = "张三";
var 年龄 = 25;
printf("--- 测试1 ---");
printf("姓名: " $ 姓名);
printf("年龄: " $ 年龄);

// ------ 测试2: 次字节0x5C变量 ------
var 匼变量 = "匼测试成功";
var 哱数据 = "哱测试成功";
printf("--- 测试2 ---");
printf(匼变量);
printf(哱数据);

// ------ 测试3: 字符串中的危险字符 ------
printf("--- 测试3 ---");
printf("包含匼字符");
printf("包含哱字符");

// ------ 测试4: 次字节{}变量 ------
var 厈数值 = 100;
var 厎结果 = 200;
printf("--- 测试4 ---");
printf("厈数值 = " $ 厈数值);
printf("厎结果 = " $ 厎结果);

// ------ 测试5: 函数危险字符 ------
function 计算匼值(甲, 乙)
{
    return 甲 + 乙;
}
printf("--- 测试5 ---");
printf("计算匼值(10,20) = " $ 计算匼值(10, 20));

/* 块注释包含匼哱危险字符 */
printf("--- 测试6: 块注释通过 ---");

// ------ 测试7: 循环 ------
printf("--- 测试7 ---");
var 匼总和 = 0;
var 匼计数 = 0;
for (匼计数 = 1; 匼计数 <= 5; 匼计数++)
{
    匼总和 = 匼总和 + 匼计数;
}
printf("匼总和 = " $ 匼总和);

printf("--- 所有GBK危险字符测试通过! ---");
system_pause();